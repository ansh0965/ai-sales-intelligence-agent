# Gemini API key (AI Studio). ADK's Gemini model reads this automatically —
# no manual client wiring needed in agent code.
# TIP: a key attached to a billing-enabled Google Cloud project is
# automatically Tier 1 (~1,000 requests/min on gemini-2.5-flash) instead of
# the free tier's ~10 requests/min. Create one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Global Gemini rate limit shared by ALL agents (see agents/rate_limiter.py).
# Free tier: keep at 4. Tier 1 / paid: raise to 30-60.
GEMINI_MAX_CALLS_PER_MINUTE=4

# Serper API (Google Search) — used by tools/web_search.py
SERPER_API_KEY=your_serper_api_key_here

# Google Sheets CRM (optional — CRM logging is skipped gracefully if unset)
GOOGLE_SHEETS_ID=your_google_sheet_id_here
GOOGLE_CREDENTIALS_PATH=credentials.json

# Force ADK to use the Gemini Developer API (AI Studio) instead of Vertex AI.
GOOGLE_GENAI_USE_VERTEXAI=False

# --- Alternative: Vertex AI (no code changes needed) ---------------------
# 1. gcloud auth application-default login
# 2. gcloud services enable aiplatform.googleapis.com --project <project-id>
# 3. Comment out GEMINI_API_KEY above and uncomment these three lines:
# GOOGLE_GENAI_USE_VERTEXAI=True
# GOOGLE_CLOUD_PROJECT=kaggle-capstone-501208
# GOOGLE_CLOUD_LOCATION=us-central1

# Optional — overrides the model used by every agent (defaults to
# gemini-2.5-flash). gemini-2.0-flash has higher free-tier limits if you
# are stuck without billing.
ADK_MODEL=gemini-2.5-flash
